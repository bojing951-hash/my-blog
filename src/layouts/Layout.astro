---
import '../styles/global.css';
import { getCollection } from 'astro:content';

// 获取统计数据
const blogPosts = await getCollection('blog');
const postCount = blogPosts.length;

// 暂时用静态数据，后续可以计算分类和标签
const categoryCount = 5; // 示例数据
const tagCount = 12; // 示例数据
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <meta name="generator" content={Astro.generator} />
  <title>{Astro.props.title ?? 'c师傅的小笨博客'}</title>
  <!-- 导入 Inter 字体 -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-white text-gray-800 font-sans min-h-screen leading-relaxed">
  <!-- 移动端菜单按钮 -->
  <button id="mobile-menu-toggle" class="fixed left-4 bottom-4 z-50 p-3 bg-gray-800 text-white rounded-full shadow-lg md:hidden" aria-label="打开菜单">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
  </button>

  <div class="flex min-h-screen">
    <!-- 左侧侧边栏 -->
    <aside id="sidebar" class="fixed inset-y-0 left-0 z-40 w-64 bg-gray-900 text-gray-200 transform -translate-x-full md:translate-x-0 md:static md:w-56 transition-transform duration-300 ease-in-out">
      <div class="h-full flex flex-col items-center justify-center p-8">
        <!-- 网站名/作者名 -->
        <h1 class="text-2xl font-bold mb-2 text-white">c师傅的小笨博客</h1>

        <!-- 简介 -->
        <p class="text-sm text-gray-400 mb-12 text-center">记录思考，分享知识</p>

        <!-- 统计数字 -->
        <div class="grid grid-cols-3 gap-6 mb-12 w-full">
          <div class="text-center">
            <div class="text-2xl font-bold text-white">{postCount}</div>
            <div class="text-xs text-gray-400 mt-1">文章</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-bold text-white">{categoryCount}</div>
            <div class="text-xs text-gray-400 mt-1">分类</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-bold text-white">{tagCount}</div>
            <div class="text-xs text-gray-400 mt-1">标签</div>
          </div>
        </div>

        <!-- RSS 链接 -->
        <a href="/rss.xml" class="flex items-center text-sm text-gray-400 hover:text-white transition-colors">
          <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19.199 24C19.199 13.467 10.533 4.8 0 4.8V0c13.165 0 24 10.835 24 24h-4.801zM3.291 17.415c1.814 0 3.293 1.479 3.293 3.295 0 1.813-1.485 3.29-3.301 3.29C1.47 24 0 22.526 0 20.71s1.475-3.295 3.291-3.295zM15.909 24h-4.665c0-6.169-5.075-11.245-11.244-11.245V8.09c8.727 0 15.909 7.184 15.909 15.91z"/>
          </svg>
          RSS 订阅
        </a>
      </div>
    </aside>

    <!-- 右侧内容区域 -->
    <div class="flex-1 flex flex-col md:ml-56">
      <!-- 顶部导航 -->
      <nav class="sticky top-0 z-30 bg-white border-b border-gray-200 py-4">
        <div class="max-w-4xl mx-auto px-4">
          <div class="flex justify-center items-center space-x-8">
            <a href="/" class="flex items-center text-sm text-gray-600 hover:text-gray-900 transition-colors">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
              </svg>
              首页
            </a>
            <a href="/about" class="flex items-center text-sm text-gray-600 hover:text-gray-900 transition-colors">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              关于
            </a>
            <a href="/tags" class="flex items-center text-sm text-gray-600 hover:text-gray-900 transition-colors">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14" />
              </svg>
              标签
            </a>
            <a href="/categories" class="flex items-center text-sm text-gray-600 hover:text-gray-900 transition-colors">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
              分类
            </a>
            <a href="/blog" class="flex items-center text-sm text-gray-600 hover:text-gray-900 transition-colors">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              归档
            </a>
            <a href="#paid" class="flex items-center text-sm text-gray-600 hover:text-gray-900 transition-colors">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
              付费投研
            </a>
          </div>
        </div>
      </nav>

      <!-- 分类子导航 -->
      <nav class="sticky top-14 z-20 bg-gray-50 border-b border-gray-200 py-3 hidden md:block">
        <div class="max-w-4xl mx-auto px-4">
          <div class="flex justify-center items-center space-x-6">
            <a href="/category/个人记录" class="text-xs text-gray-600 hover:text-gray-900 transition-colors font-medium">
              个人记录
            </a>
            <a href="/category/交易日志" class="text-xs text-gray-600 hover:text-gray-900 transition-colors font-medium">
              交易日志
            </a>
            <a href="/category/投研思考" class="text-xs text-gray-600 hover:text-gray-900 transition-colors font-medium">
              投研思考
            </a>
          </div>
        </div>
      </nav>

      <!-- 主要内容区域 -->
      <main class="flex-1 bg-gray-50">
        <div class="max-w-4xl mx-auto px-4 py-8">
          <slot />
        </div>
      </main>

      <!-- 页脚 -->
      <footer class="bg-white border-t border-gray-200 py-8">
        <div class="max-w-4xl mx-auto px-4 text-center text-gray-500 text-sm">
          <p>© {new Date().getFullYear()} c师傅的小笨博客。使用 Astro 构建，部署于 Cloudflare Pages。</p>
        </div>
      </footer>
    </div>
  </div>

  <!-- 侧边栏遮罩层 -->
  <div id="sidebar-overlay" class="fixed inset-0 bg-black bg-opacity-50 z-30 md:hidden hidden"></div>

  <script>
    // 移动端侧边栏切换
    const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
    const sidebar = document.getElementById('sidebar');
    const sidebarOverlay = document.getElementById('sidebar-overlay');

    function toggleSidebar() {
      sidebar.classList.toggle('-translate-x-full');
      sidebarOverlay.classList.toggle('hidden');
    }

    mobileMenuToggle.addEventListener('click', toggleSidebar);
    sidebarOverlay.addEventListener('click', toggleSidebar);

    // 防止侧边栏链接点击时关闭
    sidebar.addEventListener('click', (e) => {
      e.stopPropagation();
    });
  </script>
</body>
</html>
