---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 获取所有文章用于生成静态路径
export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');

  // 确保三个分类都出现在路径中，即使没有文章
  const allCategories = ['个人记录', '交易日志', '投研思考'];

  return allCategories.map((category) => ({
    params: { category },
    props: {},
  }));
}

// 从URL参数获取分类
const { category } = Astro.params;

// 验证分类参数是否有效
const validCategories = ['个人记录', '交易日志', '投研思考'];
if (!validCategories.includes(category)) {
  return Astro.redirect('/404');
}

// 获取所有文章并排序
const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// 过滤该分类的文章
const categoryPosts = sortedPosts.filter(post => post.data.category === category);

// 为"投研思考"分类添加特殊内容
const isInvestmentResearch = category === '投研思考';
---

<Layout title={`${category} - 分类`}>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <!-- 分类标题 -->
    <div class="mb-12 text-center">
      <h1 class="text-3xl font-bold text-gray-900 mb-4">{category}</h1>
      <p class="text-gray-600">
        {categoryPosts.length} 篇文章
        {isInvestmentResearch ? ' - 免费投资研究思考与观点' : ''}
      </p>
    </div>

    <!-- 投研思考分类的特殊引导 -->
    {isInvestmentResearch && (
      <div class="mb-10 p-6 bg-gray-50 border border-gray-300 rounded-lg">
        <div class="text-center">
          <p class="text-gray-700 mb-4 leading-relaxed">
            这里分享免费的投研思考与观点。如需获取更深度、系统的投研内容，请加入我的知识星球。
          </p>
          <a href="#" class="inline-flex items-center px-6 py-3 bg-gray-900 text-white font-medium rounded-md hover:bg-gray-800 transition-colors">
            加入知识星球
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    )}

    <!-- 文章列表 -->
    {categoryPosts.length > 0 ? (
      <div class="space-y-8">
        {categoryPosts.map((post) => (
          <article key={post.id} class="border-b border-gray-200 pb-8 last:border-b-0">
            <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="group">
              <h2 class="text-2xl font-bold text-gray-900 group-hover:text-gray-700 transition-colors mb-3">
                {post.data.title}
              </h2>
              <p class="text-gray-600 mb-4 leading-relaxed">
                {post.data.description}
              </p>
              <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => (
                      <span class="px-2 py-1 bg-gray-200 text-gray-700 text-xs rounded-full">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          </article>
        ))}
      </div>
    ) : (
      <div class="text-center py-12">
        <p class="text-gray-600">这个分类暂时还没有文章。</p>
        <a href="/blog" class="inline-flex items-center mt-4 text-gray-900 font-medium hover:text-gray-700 transition-colors">
          浏览所有文章
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    )}
  </div>
</Layout>