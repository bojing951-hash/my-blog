---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const blogPosts = await getCollection('blog');
const latestPosts = blogPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 5);
---

<Layout title="首页">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <!-- 欢迎区域 -->
    <section class="mb-12 text-center">
      <h1 class="text-3xl md:text-4xl font-bold mb-4 text-gray-900">c师傅的小笨博客</h1>
      <p class="text-lg text-gray-600 mb-6">记录思考，分享知识</p>
      <p class="text-gray-700 max-w-2xl mx-auto leading-relaxed">
        这里是我分享个人思考、学习笔记和投资见解的地方。内容力求简洁、有用，希望能给你带来一些启发。
      </p>
    </section>

    <!-- 最新文章 -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6 text-gray-900 border-b border-gray-300 pb-2">最新文章</h2>
      <div class="space-y-6">
        {latestPosts.map((post) => (
          <article class="border-b border-gray-200 pb-6 last:border-b-0">
            <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="group">
              <h3 class="text-xl font-medium text-gray-900 group-hover:text-gray-700 transition-colors mb-2">
                {post.data.title}
              </h3>
              <p class="text-gray-600 mb-3 leading-relaxed">
                {post.data.description}
              </p>
              <div class="flex items-center text-sm text-gray-500">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <span class="mx-2">•</span>
                <span>{post.data.author}</span>
                {post.data.tags && post.data.tags.length > 0 && (
                  <>
                    <span class="mx-2">•</span>
                    <div class="flex flex-wrap gap-2">
                      {post.data.tags.map((tag) => (
                        <span class="px-2 py-1 bg-gray-200 text-gray-700 text-xs rounded-full">
                          {tag}
                        </span>
                      ))}
                    </div>
                  </>
                )}
              </div>
            </a>
          </article>
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href="/blog" class="inline-flex items-center text-gray-900 font-medium hover:text-gray-700 transition-colors">
          浏览全部文章
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </section>

    <!-- 付费投研内容 -->
    <section id="paid" class="mb-12">
      <h2 class="text-2xl font-bold mb-6 text-gray-900 border-b border-gray-300 pb-2">付费投研内容</h2>
      <p class="text-gray-700 mb-6 leading-relaxed">深度市场分析、投资策略和独家研究报告，仅在知识星球发布。</p>
      <a href="#" class="inline-flex items-center px-6 py-3 bg-gray-900 text-white font-medium rounded-md hover:bg-gray-800 transition-colors">
        加入知识星球
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </section>

  </div>
</Layout>
