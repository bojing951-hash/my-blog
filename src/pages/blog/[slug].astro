---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  return blogPosts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

type Props = {
  post: CollectionEntry<'blog'>;
};

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title}>
  <article class="max-w-3xl mx-auto px-4 py-8">
    <header class="mb-12 pb-8 border-b border-gray-300">
      <h1 class="text-3xl md:text-4xl font-bold mb-4 text-gray-900 leading-tight">{post.data.title}</h1>
      <p class="text-lg text-gray-600 mb-6 leading-relaxed">{post.data.description}</p>
      <div class="flex flex-wrap items-center gap-4 text-gray-500 text-sm">
        <time datetime={post.data.pubDate.toISOString()} class="flex items-center">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span class="flex items-center">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          {post.data.author}
        </span>
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <span class="px-3 py-1 bg-gray-200 text-gray-700 text-sm rounded-full">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </header>

    <div class="prose prose-lg max-w-none
                prose-headings:text-gray-900
                prose-p:text-gray-700 prose-p:leading-relaxed
                prose-a:text-gray-900 prose-a:no-underline hover:prose-a:text-gray-700 hover:prose-a:underline
                prose-strong:text-gray-900
                prose-blockquote:border-l-gray-400 prose-blockquote:text-gray-600
                prose-ul:text-gray-700 prose-ol:text-gray-700
                prose-hr:border-gray-300
                prose-pre:bg-gray-100 prose-pre:border prose-pre:border-gray-300
                prose-code:text-gray-800 prose-code:bg-gray-200 prose-code:px-1 prose-code:py-0.5 prose-code:rounded
                prose-img:rounded-lg">
      <Content />
    </div>

    <div class="mt-16 pt-8 border-t border-gray-300">
      <h3 class="text-xl font-bold mb-4 text-gray-900">评论</h3>
      <p class="text-gray-600 mb-6 leading-relaxed">
        评论功能使用 Giscus 集成，基于 GitHub 讨论。请确保你已登录 GitHub 才能发表评论。
      </p>
      <div id="giscus-comments"></div>
    </div>
  </article>

  <script src="https://giscus.app/client.js"
        data-repo="bojing951-hash/my-blog-comments"
        data-repo-id="R_kgDOS7OSUg"
        data-category="Announcements"
        data-category-id="DIC_kwDOS7OSUs4C_MOE"
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="bottom"
        data-theme="preferred_color_scheme"
        data-lang="zh-CN"
        crossorigin="anonymous"
        async>
  </script>
</Layout>